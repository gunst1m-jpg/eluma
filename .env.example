# Eluma — miljøvariabler (settes i Vercel → Settings → Environment Variables).
# Kopier til .env for lokal kjøring. ALDRI commit ekte verdier — .env er gitignored.
# Full forklaring: docs/eluma-drift-oppsett.md §2.

SUPABASE_URL=                    # Prosjekt-URL fra Supabase
SUPABASE_SERVICE_ROLE_KEY=       # service_role-nøkkel (Settings → API). KUN server.
RESEND_API_KEY=                  # API-nøkkel fra Resend
VARSEL_FRA=                      # Avsender, f.eks. "Eluma <onboarding@resend.dev>"
VARSEL_TIL=                      # Din e-post — mottar varsel om nye leads/partnere
ADMIN_TOKEN=                     # Lang, tilfeldig streng = passord til /admin
SITE_URL=                        # Domenet, f.eks. https://eluma.no
PORTAL_SECRET=                   # Lang, tilfeldig streng — signerer partner-sesjon + "andre vurdering"-lenker
